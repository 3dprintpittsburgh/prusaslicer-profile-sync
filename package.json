{
  "name": "prusaslicer-profile-sync",
  "version": "1.4.0",
  "description": "Cross-platform PrusaSlicer profile sync via Git",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "3D Print Pittsburgh",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "electron-updater": "^6.8.3",
    "simple-git": "^3.27.0"
  },
  "build": {
    "appId": "com.3dprintpgh.prusaslicer-sync",
    "productName": "PrusaSlicer Profile Sync",
    "publish": {
      "provider": "github",
      "owner": "3dprintpittsburgh",
      "repo": "prusaslicer-profile-sync"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "PrusaSlicer-Profile-Sync-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
